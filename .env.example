BACKEND_PORT=4000
FRONTEND_PORT=5173
SYNC_WORKER_COUNT=3
# UTC hour when all markets are re-synced daily (default 01:00)
DAILY_SYNC_HOUR_UTC=1

DB_HOST=localhost
DB_PORT=5432
DB_NAME=binance_candles
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Must match BACKEND_PORT (and host if not localhost)
VITE_API_BASE_URL=http://localhost:4000

# Optional: full URL overrides DB_* when set
# DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/binance_candles
